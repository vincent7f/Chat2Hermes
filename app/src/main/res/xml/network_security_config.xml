<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- MVP: allow cleartext for user-configured LAN HTTP/WS. Tighten per-host in production. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
